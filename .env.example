# Copy this to .env and fill in your values

# Database — SQLite for local dev, Postgres URL for Railway production
# SQLite (default, no setup required):
DATABASE_URL=sqlite:///./data/madden_cfm.db
# PostgreSQL (Railway provides this automatically):
# DATABASE_URL=postgresql://user:password@host:5432/madden_cfm

# App settings
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-something-random-and-long
EXPORT_TOKEN=               # Optional: shared secret to validate exports from Companion App

# Raw export archive — where to store incoming JSON payloads
RAW_EXPORT_DIR=./data/raw
